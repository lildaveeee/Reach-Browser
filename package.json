{
  "name": "davos-browser",
  "version": "0.1.0",
  "description": "Electron-based browser with tabs, navigation, and webviews.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.davos.browser",
    "productName": "Davos Browser",
    "directories": {
      "output": "dist",
      "buildResources": "buildResources"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "buildResources/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "buildResources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "author": "davos",
  "license": "MIT",
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "cross-fetch": "^4.1.0"
  }
}
