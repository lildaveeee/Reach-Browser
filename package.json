{
  "name": "reach-browser",
  "version": "0.1.1",
  "description": "A browser based on navigation, functionality and customisability.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.davos.browser",
    "productName": "Reach Browser",
    "artifactName": "Reach-Browser.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "buildResources"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "buildResources/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "buildResources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "author": "daveee",
  "license": "Mozilla Public License 2.0",
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "cross-fetch": "^4.1.0"
  }
}
